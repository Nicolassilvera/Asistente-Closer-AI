{
  "manifest_version": 3,
  "name": "Jarvis Observer",
  "version": "1.0",
  "description": "Envía contexto del navegador a Jarvis",
  "permissions": ["activeTab", "tabs", "scripting", "windows"],
  "host_permissions": ["http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png"
    }
  }
}